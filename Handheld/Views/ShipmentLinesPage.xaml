<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Handheld.Views.ShipmentLinesPage"
    Title="Shipment Lines"
    Shell.BackgroundColor="{StaticResource BrandBlue}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White">

    <Grid RowDefinitions="*">

        <!-- LOADING -->
        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        <!-- NO DATA -->
        <Label
            Text="No hay líneas"
            IsVisible="{Binding IsEmpty}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            FontAttributes="Italic"
            TextColor="Gray"/>

        <!-- LIST -->
        <CollectionView
            ItemsSource="{Binding Lines}"
            IsVisible="{Binding HasData}"
            SelectionMode="None">

            <CollectionView.Header>
                <Grid BackgroundColor="#E5E7EB"
                      ColumnDefinitions="3*,1*,1*,1*">
                    <Label Text="Item" Padding="8" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Ord." Padding="8" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Grid.Column="2" Text="Rem." Padding="8" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Grid.Column="3" Text="Status" Padding="8" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8"
                          ColumnDefinitions="3*,1*,1*,1*">

                        <Label Text="{Binding ItemNo}" />

                        <Label Grid.Column="1"
                               Text="{Binding OrderedQty}"
                               HorizontalTextAlignment="Center"/>

                        <Label Grid.Column="2"
                               Text="{Binding RemainingQty}"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>

                        <Label Grid.Column="3"
                               Text="{Binding LineStatus}"
                               HorizontalTextAlignment="Center"/>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
