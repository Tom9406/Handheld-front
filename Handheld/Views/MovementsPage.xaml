<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Handheld.Views.MovementsPage"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- TOP BAR -->
        <Grid
            Grid.Row="0"
            BackgroundColor="{StaticResource BrandBlue}"
            HeightRequest="64"
            Padding="12"
            ColumnDefinitions="Auto,*">

            <Label
                Text="☰"
                FontSize="22"
                TextColor="White"
                VerticalOptions="Center"/>

            <Label
                Grid.Column="1"
                Text="Inventory Movements"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="White"/>
        </Grid>

        <!-- CONTENT -->
        <Grid
            Grid.Row="1"
            RowDefinitions="Auto,Auto,*">

            <!-- LOADING (overlay) -->
            <ActivityIndicator
                x:Name="LoadingIndicator"
                Grid.RowSpan="3"
                IsVisible="False"
                IsRunning="False"
                HorizontalOptions="Center"
                VerticalOptions="Center"/>

            <!-- ERROR (overlay) -->
            <Label
                x:Name="ErrorLabel"
                Grid.RowSpan="3"
                IsVisible="False"
                TextColor="Red"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                VerticalOptions="Center"/>

            <!-- SEARCH / SCAN -->
            <Entry
                Grid.Row="0"
                x:Name="SearchEntry"
                Placeholder="Scan Item / Bin / Movement / Reference..."
                ReturnType="Search"
                Completed="OnSearchCompleted"
                ClearButtonVisibility="WhileEditing"
                Margin="10"
                BackgroundColor="#F3F4F6" />

            <!-- MOVEMENTS LIST -->
            <CollectionView
                Grid.Row="2"
                x:Name="MovementList"
                IsVisible="False"
                SelectionMode="None"
                BackgroundColor="White">

                <!-- HEADER -->
                <CollectionView.Header>
                    <Grid
                        BackgroundColor="#E5E7EB"
                        ColumnDefinitions="2*,2*,2*,2*">

                        <Label
                            Text="Item"
                            Padding="8"
                            FontAttributes="Bold"/>

                        <Label
                            Grid.Column="1"
                            Text="Bin"
                            Padding="8"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            Grid.Column="2"
                            Text="Qty"
                            Padding="8"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            Grid.Column="3"
                            Text="Type"
                            Padding="8"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"/>
                    </Grid>
                </CollectionView.Header>

                <!-- Movement -->
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            Padding="8"
                            ColumnDefinitions="2*,2*,2*,2*">

                            <Label
                                Text="{Binding ItemNo}" />

                            <Label
                                Grid.Column="1"
                                Text="{Binding BinCode}"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                Grid.Column="2"
                                Text="{Binding Quantity}"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                Grid.Column="3"
                                Text="{Binding MovementType}"
                                HorizontalTextAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

    </Grid>
</ContentPage>
