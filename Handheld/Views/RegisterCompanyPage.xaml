<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Handheld.Views.RegisterCompanyPage"
    Title="Register Company"
    BackgroundColor="{StaticResource BrandBlue}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label Text="Register Company"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   Padding="20"                   
                   HasShadow="True">

                <VerticalStackLayout Spacing="14">

                    <Entry Placeholder="Company Code"
                           PlaceholderColor="Black"
                           Text="{Binding Code}" 
                           TextColor="Black"/>

                    <Entry Placeholder="Company Name"
                           PlaceholderColor="Black"
                           Text="{Binding Name}" 
                           TextColor="Black" />

                    <Entry Placeholder="Currency Code (USD)"
                           PlaceholderColor="Black"
                           Text="{Binding CurrencyCode}" 
                           TextColor="Black" />

                    <Entry Placeholder="Time Zone (UTC)"
                           PlaceholderColor="Black"
                           Text="{Binding TimeZone}" 
                           TextColor="Black" />

                    <Entry Placeholder="Company Type"
                           PlaceholderColor="Black"
                           Text="{Binding CompanyType}" 
                           TextColor="Black" />

                    <Entry Placeholder="Legal Name"
                           PlaceholderColor="Black"
                           Text="{Binding LegalName}" 
                           TextColor="Black"/>

                    <Entry Placeholder="Tax ID"
                           PlaceholderColor="Black"
                           Text="{Binding TaxId}" 
                           TextColor="Black"/>

                    <Entry Placeholder="Address"
                           PlaceholderColor="Black"
                           Text="{Binding Address1}" 
                           TextColor="Black"/>

                    <Entry Placeholder="City"
                           PlaceholderColor="Black"
                           Text="{Binding City}" 
                           TextColor="Black"/>

                    <Entry Placeholder="Country"
                           PlaceholderColor="Black"
                           Text="{Binding Country}" 
                           TextColor="Black"/>

                    <Button Text="Register Company"
                            BackgroundColor="{StaticResource BrandBlue}"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="48"
                            Command="{Binding CreateCompanyCommand}" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
